<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SST.ViewModels"
             xmlns:sys="using:System"
             mc:Ignorable="d" d:DesignWidth="980" d:DesignHeight="640"
             x:Class="SST.Views.InspectorView"
             x:DataType="vm:InspectorViewModel">

  <Design.DataContext>
    <vm:InspectorViewModel/>
  </Design.DataContext>

  <DockPanel Margin="6">
    <StackPanel DockPanel.Dock="Top" Spacing="3">
      <TextBlock Classes="muted" TextWrapping="Wrap" FontSize="9"
                 Text="Inspect .dat — hex first 4 MiB; strings heuristic; diff uses shared prefix if lengths differ."/>
      <StackPanel Orientation="Horizontal" Spacing="4">
        <Button Content="Open…" Command="{Binding OpenFileCommand}"/>
        <TextBlock VerticalAlignment="Center" FontSize="10" Text="Busy…" IsVisible="{Binding IsBusy}"/>
      </StackPanel>
      <TextBlock Classes="muted" TextWrapping="Wrap" Text="{Binding DecoderNote}"/>
    </StackPanel>

    <TabControl>
      <TabItem Header="Details">
        <StackPanel Margin="4" Spacing="2">
          <TextBlock Text="{Binding CurrentPath}" TextWrapping="Wrap" FontSize="10"/>
          <TextBlock FontSize="10" Text="{Binding FileSizeBytes, StringFormat=Size: {0} bytes}"/>
          <TextBlock FontSize="10" Text="{Binding InferredKind, StringFormat=Inferred: {0}}"/>
          <TextBlock FontSize="10" Text="{Binding ModifiedUtc, StringFormat=Modified (UTC): {0:O}}"/>
        </StackPanel>
      </TabItem>

      <TabItem Header="Hex">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
          <ListBox x:CompileBindings="False"
                   ItemsSource="{Binding HexLines}"
                   BorderThickness="0"
                   Background="Transparent">
            <ListBox.Styles>
              <Style Selector="ListBoxItem">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="MinHeight" Value="0"/>
              </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
              <DataTemplate DataType="sys:String">
                <TextBlock FontFamily="{DynamicResource EveMonoFont}" FontSize="9" Text="{Binding}"/>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Strings">
        <DataGrid ItemsSource="{Binding Strings}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserResizeColumns="True">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Off" Binding="{Binding Offset}" Width="72"/>
            <DataGridTextColumn Header="Enc" Binding="{Binding EncodingName}" Width="72"/>
            <DataGridTextColumn Header="Text" Binding="{Binding Text}" Width="*"/>
          </DataGrid.Columns>
        </DataGrid>
      </TabItem>

      <TabItem Header="Diff">
        <Grid Margin="4" RowDefinitions="Auto,Auto,Auto,*" ColumnDefinitions="*,Auto" RowSpacing="3" ColumnSpacing="4">
          <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Classes="muted" TextWrapping="Wrap" FontSize="9"
                     Text="Two captures of the same file (one UI change between). Pick A and B."/>

          <TextBox Grid.Row="1" Grid.Column="0" PlaceholderText="File A" Text="{Binding DiffPathA}" IsReadOnly="True"/>
          <Button Grid.Row="1" Grid.Column="1" Content="A" Command="{Binding PickDiffACommand}" MinWidth="44"/>

          <TextBox Grid.Row="2" Grid.Column="0" PlaceholderText="File B" Text="{Binding DiffPathB}" IsReadOnly="True"/>
          <Button Grid.Row="2" Grid.Column="1" Content="B" Command="{Binding PickDiffBCommand}" MinWidth="44"/>

          <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Spacing="3">
            <Button HorizontalAlignment="Left" Content="Run diff" Command="{Binding RunDiffCommand}"/>
            <TextBlock Classes="muted" TextWrapping="Wrap" Text="{Binding DiffSummary}"/>
          </StackPanel>
        </Grid>
      </TabItem>

      <TabItem Header="Records">
        <DataGrid ItemsSource="{Binding Records}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Offset" Binding="{Binding Offset}" Width="88"/>
            <DataGridTextColumn Header="Len" Binding="{Binding Length}" Width="48"/>
            <DataGridTextColumn Header="Kind" Binding="{Binding KindGuess}" Width="100"/>
            <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="*"/>
          </DataGrid.Columns>
        </DataGrid>
      </TabItem>
    </TabControl>
  </DockPanel>
</UserControl>
