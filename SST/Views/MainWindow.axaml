<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SST.ViewModels"
        xmlns:views="using:SST.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="460" d:DesignHeight="670"
        Width="460" Height="670" CanResize="false"
        x:Class="SST.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/SST.ico"
        Title="SST - Eve Setting Tool">

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <DockPanel Background="{DynamicResource EveBgBrush}">
      <views:SyncView DataContext="{Binding Sync}" VerticalAlignment="Top"/>
  </DockPanel>
</Window>
