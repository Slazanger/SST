<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EveSettings.ViewModels"
             mc:Ignorable="d" d:DesignWidth="980" d:DesignHeight="640"
             x:Class="EveSettings.Views.SyncView"
             x:DataType="vm:SyncViewModel">

  <Design.DataContext>
    <vm:SyncViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,200" Margin="12" RowSpacing="10">
    <TextBlock Grid.Row="0" TextWrapping="Wrap"
               Text="Copy raw bytes from a master core_char / core_user pair onto other local .dat files. Close EVE first."/>

    <DockPanel Grid.Row="1" LastChildFill="True">
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <TextBlock VerticalAlignment="Center" Text="Busy…" IsVisible="{Binding IsBusy}"/>
        <Button Content="Apply" Command="{Binding ApplyCommand}"/>
      </StackPanel>

      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBox MinWidth="480" PlaceholderText="EVE local settings folder" Text="{Binding EveRootPath}" IsReadOnly="True"/>
        <Button Content="Browse…" Command="{Binding BrowseCommand}"/>
        <Button Content="Scan" Command="{Binding ScanCommand}"/>
      </StackPanel>
    </DockPanel>

    <StackPanel Grid.Row="2" Spacing="6">
      <TextBlock FontWeight="Bold" Text="Server"/>
      <ComboBox MinWidth="360" HorizontalAlignment="Left"
                ItemsSource="{Binding Servers}"
                SelectedItem="{Binding SelectedServer}">
        <ComboBox.ItemTemplate>
          <DataTemplate x:DataType="vm:ServerListItem">
            <StackPanel Spacing="2">
              <TextBlock Text="{Binding DisplayLabel}" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding FolderName}" Opacity="0.7" FontSize="12"/>
            </StackPanel>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </StackPanel>

    <Grid Grid.Row="3" ColumnDefinitions="360,*" ColumnSpacing="12">
      <StackPanel Grid.Column="0" Spacing="10">
        <TextBlock FontWeight="Bold" Text="Masters"/>
        <TextBlock Text="Master core_char_*.dat"/>
        <ComboBox ItemsSource="{Binding CharFiles}"
                  SelectedItem="{Binding MasterChar}"
                  MinHeight="32">
          <ComboBox.ItemTemplate>
            <DataTemplate x:DataType="vm:CharacterNamedFileItem">
              <TextBlock Text="{Binding DisplayLine}" TextTrimming="CharacterEllipsis"/>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Text="Master core_user_*.dat"/>
        <ComboBox ItemsSource="{Binding UserFiles}"
                  SelectedItem="{Binding MasterUser}"
                  MinHeight="32">
          <ComboBox.ItemTemplate>
            <DataTemplate x:DataType="vm:CharacterNamedFileItem">
              <TextBlock Text="{Binding DisplayLine}" TextTrimming="CharacterEllipsis"/>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
      </StackPanel>

      <DockPanel Grid.Column="1">
        <TextBlock DockPanel.Dock="Top" FontWeight="Bold" Text="Targets (checkboxes)"/>
        <Border BorderBrush="#40000000" BorderThickness="1" Padding="6">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding TargetRows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:SelectableFileRow">
                  <CheckBox Margin="0,2,0,2" IsChecked="{Binding IsSelected}">
                    <TextBlock Text="{Binding DisplayLine}" TextTrimming="CharacterEllipsis"/>
                  </CheckBox>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>
      </DockPanel>
    </Grid>

    <DockPanel Grid.Row="4" LastChildFill="True">
      <DockPanel DockPanel.Dock="Top" LastChildFill="False">
        <TextBlock DockPanel.Dock="Left" FontWeight="Bold" Text="Copy log" VerticalAlignment="Center"/>
        <Button DockPanel.Dock="Right" Content="Clear log" Command="{Binding ClearCopyLogCommand}" Padding="10,4"/>
      </DockPanel>
      <Border Margin="0,6,0,0" BorderBrush="#40000000" BorderThickness="1" Padding="4">
        <ListBox x:CompileBindings="False"
                 ItemsSource="{Binding CopyLog}"
                 FontFamily="Consolas, Cascadia Mono, Courier New, monospace"
                 FontSize="12"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
      </Border>
    </DockPanel>

    <TextBlock Grid.Row="5" TextWrapping="Wrap" Opacity="0.85" Text="{Binding StatusMessage}"/>
  </Grid>
</UserControl>
