<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EveSettings.ViewModels"
             xmlns:sys="using:System"
             mc:Ignorable="d" d:DesignWidth="980" d:DesignHeight="640"
             x:Class="EveSettings.Views.InspectorView"
             x:DataType="vm:InspectorViewModel">

  <Design.DataContext>
    <vm:InspectorViewModel/>
  </Design.DataContext>

  <DockPanel Margin="12">
    <StackPanel DockPanel.Dock="Top" Spacing="8">
      <TextBlock TextWrapping="Wrap"
                 Text="Inspect a local .dat file. Hex is limited to the first 4 MiB. Strings extraction is heuristic. Diff compares the shared prefix when lengths differ."/>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="Open .dat…" Command="{Binding OpenFileCommand}"/>
        <TextBlock VerticalAlignment="Center" Text="Busy…" IsVisible="{Binding IsBusy}"/>
      </StackPanel>
      <TextBlock TextWrapping="Wrap" Opacity="0.85" Text="{Binding DecoderNote}"/>
    </StackPanel>

    <TabControl>
      <TabItem Header="Details">
        <StackPanel Margin="8" Spacing="6">
          <TextBlock Text="{Binding CurrentPath}" TextWrapping="Wrap"/>
          <TextBlock Text="{Binding FileSizeBytes, StringFormat=Size: {0} bytes}"/>
          <TextBlock Text="{Binding InferredKind, StringFormat=Inferred: {0}}"/>
          <TextBlock Text="{Binding ModifiedUtc, StringFormat=Modified (UTC): {0:O}}"/>
        </StackPanel>
      </TabItem>

      <TabItem Header="Hex (first 4 MiB)">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
          <ListBox x:CompileBindings="False"
                   ItemsSource="{Binding HexLines}"
                   BorderThickness="0"
                   Background="Transparent">
            <ListBox.Styles>
              <Style Selector="ListBoxItem">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="MinHeight" Value="0"/>
              </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
              <DataTemplate DataType="sys:String">
                <TextBlock FontFamily="Consolas, Courier New, monospace" Text="{Binding}"/>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Strings">
        <DataGrid ItemsSource="{Binding Strings}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserResizeColumns="True">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Offset" Binding="{Binding Offset}" Width="90"/>
            <DataGridTextColumn Header="Encoding" Binding="{Binding EncodingName}" Width="90"/>
            <DataGridTextColumn Header="Text" Binding="{Binding Text}" Width="*"/>
          </DataGrid.Columns>
        </DataGrid>
      </TabItem>

      <TabItem Header="Diff">
        <Grid Margin="8" RowDefinitions="Auto,Auto,Auto,*" ColumnDefinitions="*,Auto" RowSpacing="8" ColumnSpacing="8">
          <TextBlock Grid.Row="0" Grid.ColumnSpan="2" TextWrapping="Wrap"
                     Text="Workflow: log in, change exactly one UI setting, log out, copy the same .dat twice (before/after). Pick both files here."/>

          <TextBox Grid.Row="1" Grid.Column="0" Watermark="File A" Text="{Binding DiffPathA}" IsReadOnly="True"/>
          <Button Grid.Row="1" Grid.Column="1" Content="Pick A" Command="{Binding PickDiffACommand}"/>

          <TextBox Grid.Row="2" Grid.Column="0" Watermark="File B" Text="{Binding DiffPathB}" IsReadOnly="True"/>
          <Button Grid.Row="2" Grid.Column="1" Content="Pick B" Command="{Binding PickDiffBCommand}"/>

          <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Spacing="8">
            <Button HorizontalAlignment="Left" Content="Run diff" Command="{Binding RunDiffCommand}"/>
            <TextBlock TextWrapping="Wrap" Text="{Binding DiffSummary}"/>
          </StackPanel>
        </Grid>
      </TabItem>

      <TabItem Header="Records (heuristic)">
        <DataGrid ItemsSource="{Binding Records}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Offset" Binding="{Binding Offset}" Width="110"/>
            <DataGridTextColumn Header="Length" Binding="{Binding Length}" Width="80"/>
            <DataGridTextColumn Header="Kind" Binding="{Binding KindGuess}" Width="140"/>
            <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="*"/>
          </DataGrid.Columns>
        </DataGrid>
      </TabItem>
    </TabControl>
  </DockPanel>
</UserControl>
